# Telegram user IDs that can open /admin. Use comma-separated numeric IDs.
ADMIN_IDS=123456789

# Main VPN bot shown in public buttons.
MAIN_BOT_USERNAME=your_vpn_bot
MAIN_BOT_URL=https://t.me/your_vpn_bot

# Optional fallback if bot_tokens.json is empty or absent.
# Prefer putting tokens into bot_tokens.json on the server.
BOT_TOKENS=123456789:replace_with_token
